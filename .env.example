# ===========================================================================
# Wisecofre - Variaveis de Ambiente
# ===========================================================================
# Copie para .env e ajuste os valores.
# Para Docker local: use os defaults do docker-compose.yml (nao precisa .env).
# Para producao (Coolify): use .env.coolify como base.
# ===========================================================================

# --- Django ----------------------------------------------------------------
SECRET_KEY=GERAR-COM: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.production

# --- Seguranca (False para HTTP local, True para HTTPS producao) -----------
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# --- Database --------------------------------------------------------------
# Dev local sem Docker: localhost:5432 | Docker: db:5432
DATABASE_URL=postgresql://wisecofre:password@localhost:5432/wisecofre
POSTGRES_DB=wisecofre
POSTGRES_USER=wisecofre
POSTGRES_PASSWORD=password

# --- MinIO / S3 ------------------------------------------------------------
# Dev local sem Docker: localhost:9000 | Docker: minio:9000
MINIO_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=wisecofre-access-key
STORAGE_SECRET_KEY=wisecofre-secret-key-muito-longa
MINIO_BUCKET_NAME=wisecofre-files
MINIO_USE_HTTPS=False

# --- App -------------------------------------------------------------------
APP_BASE_URL=http://localhost:8003
APP_NAME=Wisecofre
ENCRYPTION_KEY=GERAR-COM: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# --- CSRF / CORS (ajustar para seu dominio em producao) --------------------
CSRF_TRUSTED_ORIGINS=http://localhost:8003
CORS_ALLOWED_ORIGINS=http://localhost:8003

# --- Email -----------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USE_TLS=False
DEFAULT_FROM_EMAIL=wisecofre@localhost

# --- JWT -------------------------------------------------------------------
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# --- Limites ---------------------------------------------------------------
FILE_MAX_SIZE_BYTES=10485760
MINIO_PRESIGNED_URL_EXPIRY_SECONDS=60
MINIO_UPLOAD_URL_EXPIRY_SECONDS=900
